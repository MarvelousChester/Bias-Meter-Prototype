{
  "name": "bias-mate-extension",
  "description": "Browser extension for analyzing YouTube video bias",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
