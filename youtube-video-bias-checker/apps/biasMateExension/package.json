    "lucide-react": "^0.562.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "supabase": "^2.71.0",
    "tailwindcss": "^4.1.18",
    "youtube-transcript-plus": "^1.1.1"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@wxt-dev/module-react": "^1.1.2",
    "typescript": "^5.9.3",
